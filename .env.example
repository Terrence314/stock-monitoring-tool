# ── Required ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Optional ───────────────────────────────────────────────────────────────────
# URL of your GitHub Pages report — shown as link in Telegram message
# e.g. https://yourusername.github.io/stock-monitoring-tool/
REPORT_URL=

# ── How to get each value ─────────────────────────────────────────────────────
#
# GEMINI_API_KEY
#   → https://aistudio.google.com/app/apikey
#   → Free tier: 15 req/min, 1500 req/day — sufficient for daily runs
#
# TELEGRAM_BOT_TOKEN
#   → Open Telegram → search @BotFather → /newbot → follow prompts
#   → Copy the token it gives you
#
# TELEGRAM_CHAT_ID
#   → Send any message to your new bot
#   → Open: https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#   → Find "chat" → "id" in the response
#
# REPORT_URL (GitHub Pages)
#   → Push this repo to GitHub
#   → Settings → Pages → Source: gh-pages branch → / (root)
#   → URL will be https://<username>.github.io/<repo-name>/
